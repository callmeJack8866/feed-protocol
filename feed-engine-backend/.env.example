# Runtime
NODE_ENV=development
PORT=3001

# Database / cache
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/feed_engine?schema=public"
REDIS_URL="redis://localhost:6379"

# Browser origins used by CORS and SIWE message construction
FRONTEND_URL="http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173,http://localhost:3000"

# Auth
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_ADDRESSES=0xAdminWallet1,0xAdminWallet2

# Chain RPC
BSC_RPC_URL=https://bsc-dataseed.binance.org/
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545/
CHAIN_RPC_URL=https://bsc-dataseed.binance.org/

# Operational wallets / signers
BACKEND_PRIVATE_KEY=
MINTER_PRIVATE_KEY=
NST_FEED_SUBMITTER_PRIVATE_KEY=
PLATFORM_WALLET=0x0000000000000000000000000000000000000001
DAO_TREASURY_WALLET=0x0000000000000000000000000000000000000002

# Core contracts
FEED_ENGINE_CONTRACT=
FEED_TOKEN_CONTRACT=
FEEDER_LICENSE_NFT_CONTRACT=
FEED_CONSENSUS_CONTRACT=
REWARD_PENALTY_CONTRACT=
USDT_TOKEN_CONTRACT=

# NFT / achievement contracts
BADGE_NFT_CONTRACT=

# NST integration
NST_OPTIONS_CORE_CONTRACT=
NST_FEED_PROTOCOL_CONTRACT=
PROTOCOL_API_KEYS="replace-me:NST"
WEBHOOK_SECRET=replace-with-webhook-secret

# IPFS / Pinata
PINATA_JWT=
PINATA_API_KEY=
PINATA_SECRET_KEY=
PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs
