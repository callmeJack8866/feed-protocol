// Feed Engine — Prisma Schema (PostgreSQL 上线版)
// 迁移自 SQLite，适配 PostgreSQL 特性

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================================
// 喂价员体系 (Feeder System)
// ========================================

// 喂价员
model Feeder {
  id              String    @id @default(uuid())
  address         String    @unique // 钱包地址
  nickname        String?
  rank            String    @default("F") // F/E/D/C/B/A/S
  xp              Int       @default(0)
  totalFeeds      Int       @default(0)
  accuracyRate    Float     @default(0)
  avgDeviation    Float     @default(0)
  totalEarnings   Float     @default(0) // 总收益 (FEED)
  stakedAmount    Float     @default(0)
  stakeType       String    @default("USDT") // FEED/USDT/NFT
  nftLicenseId    String?   // NFT 执照 ID
  
  // 偏好设置 (PostgreSQL Json 类型)
  countries       Json      @default("[]") // ["US", "CN", "HK"]
  exchanges       Json      @default("[]") // ["NYSE", "SSE", "BINANCE"]
  assetTypes      Json      @default("[]") // ["CRYPTO", "US_STOCK", "CN_STOCK"]
  
  // 状态
  isBanned        Boolean   @default(false)
  banUntil        DateTime?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  submissions     PriceSubmission[]
  history         FeedHistory[]
  dailyTasks      DailyTask[]
  stakeRecords    StakeRecord[]
  trainingRecords FeederTrainingRecord[]
  achievements    FeederAchievement[]
  penalties       FeederPenaltyRecord[]

  @@index([rank])
  @@index([address])
  @@index([isBanned])
}

// 质押记录
model StakeRecord {
  id              String   @id @default(uuid())
  feederId        String
  
  // 质押信息
  stakeType       String   // FEED / USDT / NFT
  amount          Float    // 质押金额 (FEED/USDT 数量)
  nftTokenId      String?  // NFT Token ID (如果是 NFT 质押)
  
  // 交易信息
  txHash          String   // 链上交易哈希
  blockNumber     Int?
  
  // 状态
  status          String   @default("ACTIVE") // ACTIVE / UNLOCKING / WITHDRAWN / SLASHED
  
  // 解锁相关 (30天冷却期)
  unlockRequestedAt DateTime? // 申请解锁时间
  unlockAvailableAt DateTime? // 可提取时间 (申请后 30 天)
  withdrawnAt       DateTime? // 实际提取时间
  withdrawTxHash    String?   // 提取交易哈希
  
  // 惩罚相关
  slashedAmount   Float     @default(0) // 被罚没金额
  slashReason     String?   // 罚没原因
  slashTxHash     String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  feeder          Feeder   @relation(fields: [feederId], references: [id])

  @@index([feederId])
  @@index([status])
}

// NFT 执照
model FeederLicense {
  id              String   @id @default(uuid())
  tokenId         String   @unique // 链上 Token ID
  
  // NFT 元数据
  name            String   // 如 "Gold Feeder License #123"
  tier            String   // BRONZE / SILVER / GOLD / PLATINUM / DIAMOND
  maxRank         String   // 该执照允许的最高等级
  
  // 权益
  dailyLimit      Int      // 每日抢单上限
  feeDiscount     Float    @default(0) // 费用折扣百分比
  
  // 当前持有人
  ownerId         String?  // 当前持有的喂价员 ID
  ownerAddress    String?  // 当前持有人钱包地址
  
  // 是否用于质押
  isStaked        Boolean  @default(false)
  stakedBy        String?  // 质押者 ID
  
  // 历史
  mintedAt        DateTime @default(now())
  lastTransferAt  DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([ownerAddress])
}

// ========================================
// 订单系统 (Order System)
// ========================================

// 喂价订单
model Order {
  id                String    @id @default(uuid())
  symbol            String    // 标的代码 (AAPL, BTC-USDT, 600519.SH)
  market            String    // CRYPTO/US_STOCK/CN_STOCK/HK_STOCK/FOREX/COMMODITY
  country           String    // US/CN/HK/JP/KR/GLOBAL
  exchange          String    // NYSE/NASDAQ/SSE/BINANCE
  feedType          String    // INITIAL/DYNAMIC/SETTLEMENT/ARBITRATION
  
  // 金额与共识配置
  notionalAmount    Float     // 名义本金额度 (USDT)
  requiredFeeders   Int       // 需要的喂价员数量
  consensusThreshold String   // 共识门槛 (2/3, 3/5, 5/7)
  
  // 特殊条件 (PostgreSQL Json)
  specialConditions Json      @default("[]")
  
  // 奖励
  rewardAmount      Float     // 奖励金额 (FEED)
  feeAmount         Float     @default(5) // 固定费用 (USDT): Initial=5/Dynamic=5/Settlement=10/Arbitration=20
  
  // 时间控制
  grabTimeout       Int       @default(300) // 抢单超时（秒）
  feedTimeout       Int       @default(600) // 喂价超时（秒）
  expiresAt         DateTime  // 订单过期时间
  
  // 状态
  status            String    @default("OPEN") // OPEN/GRABBED/FEEDING/CONSENSUS/SETTLED/DISPUTED/EXPIRED
  
  // 存储
  ipfsHash          String?   // IPFS 订单详情哈希
  
  // 结果
  finalPrice        Float?    // 最终共识价格
  settledAt         DateTime?
  txHash            String?   // 链上交易哈希
  
  // 来源协议
  sourceProtocol    String?   // NST 或其他协议
  callbackUrl       String?   // 回调地址
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  submissions       PriceSubmission[]
  observers         OrderObserver[]
  rewardDistributions RewardDistribution[]

  @@index([status, createdAt])
  @@index([market, country])
  @@index([feedType])
  @@index([sourceProtocol])
}

// 价格提交
model PriceSubmission {
  id            String    @id @default(uuid())
  orderId       String
  feederId      String
  
  // Commit 阶段
  priceHash     String?   // keccak256(price + salt)
  commitTxHash  String?
  committedAt   DateTime?
  
  // Reveal 阶段
  revealedPrice Float?
  salt          String?
  revealTxHash  String?
  revealedAt    DateTime?
  
  // 验证
  screenshot    String?   // IPFS 截图哈希
  deviation     Float?    // 与共识价格的偏差
  isValid       Boolean   @default(true)
  
  // 奖惩
  rewardEarned  Float?
  penaltyAmount Float?
  xpEarned      Int?
  
  createdAt     DateTime  @default(now())
  
  order         Order     @relation(fields: [orderId], references: [id])
  feeder        Feeder    @relation(fields: [feederId], references: [id])
  
  @@unique([orderId, feederId])
  @@index([orderId])
  @@index([feederId])
}

// 订单观察者（未抢中但可见）
model OrderObserver {
  id        String   @id @default(uuid())
  orderId   String
  feederId  String
  createdAt DateTime @default(now())
  
  order     Order    @relation(fields: [orderId], references: [id])
  
  @@unique([orderId, feederId])
}

// ========================================
// 奖励分配 (Reward Distribution)
// ========================================

// 奖励分配记录 — 方案 §9.1 (70/10/10/10)
model RewardDistribution {
  id              String   @id @default(uuid())
  orderId         String
  
  // 分配金额
  totalReward     Float    // 总奖励
  feederTotal     Float    // 喂价员总额 (70%)
  platformFee     Float    // 平台运营 (10%)
  daoFee          Float    // DAO 金库 (10%)
  burnAmount      Float    // 代币销毁 (10%)
  
  // 喂价员明细 (JSON: { feederId: amount })
  feederShares    Json     // 各喂价员分得金额
  
  // 目标钱包
  platformWallet  String   // 平台运营钱包
  daoWallet       String   // DAO 金库钱包
  burnAddress     String   // 销毁地址
  
  // 状态
  status          String   @default("PENDING") // PENDING / DISTRIBUTED / FAILED
  
  // 链上交易
  txHash          String?  // 分配交易哈希
  distributedAt   DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  order           Order    @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([status])
}

// ========================================
// 惩罚记录 (Penalty Records)
// ========================================

// 喂价员惩罚记录 — 方案 §9.2
model FeederPenaltyRecord {
  id              String   @id @default(uuid())
  feederId        String
  orderId         String?  // 关联订单（如有）
  
  // 惩罚详情
  level           String   // MINOR / MODERATE / SEVERE / EXTREME
  reason          String   // 触发原因
  description     String?  // 详细描述
  
  // 惩罚内容
  rewardForfeited Float    @default(0)  // 扣除本单奖励
  stakeSlashed    Float    @default(0)  // 扣除质押比例金额
  xpDeducted      Int      @default(0)  // 扣除经验值
  rankDemoted     Int      @default(0)  // 等级降级数
  banDays         Int      @default(0)  // 禁止抢单天数
  
  // 链上记录
  txHash          String?
  
  createdAt       DateTime @default(now())
  
  feeder          Feeder   @relation(fields: [feederId], references: [id])

  @@index([feederId])
  @@index([level])
}

// ========================================
// 喂价历史与任务 (History & Tasks)
// ========================================

// 喂价历史
model FeedHistory {
  id        String   @id @default(uuid())
  feederId  String
  orderId   String
  symbol    String
  market    String
  price     Float
  deviation Float
  reward    Float
  xpEarned  Int
  createdAt DateTime @default(now())
  
  feeder    Feeder   @relation(fields: [feederId], references: [id])

  @@index([feederId, createdAt])
  @@index([orderId])
}

// 每日任务
model DailyTask {
  id          String   @id @default(uuid())
  feederId    String
  date        DateTime @default(now()) @db.Date
  feedCount   Int      @default(0)
  target1     Boolean  @default(false) // 完成1单
  target3     Boolean  @default(false) // 完成3单
  target5     Boolean  @default(false) // 完成5单
  xpClaimed   Int      @default(0)
  
  feeder      Feeder   @relation(fields: [feederId], references: [id])
  
  @@unique([feederId, date])
}

// ========================================
// 赛季管理系统 (Season Management)
// ========================================

// 赛季排行榜快照
model SeasonSnapshot {
  id        String   @id @default(uuid())
  season    String   // 2026-01
  seasonId  String?  // 关联赛季 ID
  feederId  String
  rank      Int
  rankType  String   @default("OVERALL") // OVERALL / FEEDS / ACCURACY / SPEED / STAKING
  totalXp   Int
  feeds     Int
  accuracy  Float
  avgSpeed  Float?   // 平均响应速度（秒）
  reward    Float?
  createdAt DateTime @default(now())
  
  seasonRef Season?  @relation(fields: [seasonId], references: [id])
  
  @@unique([season, feederId, rankType])
  @@index([season])
}

// 赛季
model Season {
  id           String   @id @default(uuid())
  name         String   // "2026年1月赛季"
  code         String   @unique // "2026-01"
  startDate    DateTime
  endDate      DateTime
  status       String   @default("UPCOMING") // UPCOMING / ACTIVE / ENDED / SETTLED
  
  // 奖励配置 (JSON)
  rewardConfig Json     // 各名次奖励配置
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  snapshots    SeasonSnapshot[]

  @@index([status])
}

// ========================================
// 仲裁系统 (Arbitration System)
// ========================================

// 仲裁案件
model ArbitrationCase {
  id              String   @id @default(uuid())
  orderId         String   // 关联的订单
  initiatorId     String   // 发起人 (喂价员或用户)
  initiatorType   String   // FEEDER / USER / SYSTEM
  
  // 争议信息
  disputeReason   String   // 争议原因
  description     String   // 详细描述
  evidenceUrls    Json     @default("[]") // IPFS 证据链接
  
  // 涉及的喂价员
  disputedFeederId String? // 被争议的喂价员
  
  // 仲裁类型
  caseType        String   @default("NORMAL") // NORMAL / ADVANCED
  
  // 押金 (§10.3: 50 USDT)
  depositAmount   Float    @default(50) // 押金金额 (USDT)
  depositPaid     Boolean  @default(false)
  depositTxHash   String?
  
  // 仲裁员 (JSON: 喂价员ID数组)
  arbitrators     Json     @default("[]")
  requiredVotes   Int      @default(3) // 所需投票数
  
  // 状态
  status          String   @default("PENDING") // PENDING / VOTING / RESOLVED / CANCELLED
  
  // 结果
  verdict         String?  // INITIATOR_WIN / INITIATOR_LOSE / INCONCLUSIVE
  verdictReason   String?
  
  // 押金处理
  depositReturned Boolean  @default(false)
  
  // 时间
  votingDeadline  DateTime?
  resolvedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  votes           ArbitrationVote[]
  appeals         Appeal[]

  @@index([orderId])
  @@index([status])
}

// 仲裁投票
model ArbitrationVote {
  id           String   @id @default(uuid())
  caseId       String
  arbitratorId String   // 仲裁员 (喂价员ID)
  
  // 投票内容
  vote         String   // SUPPORT_INITIATOR / REJECT_INITIATOR / ABSTAIN
  reason       String?  // 投票理由
  
  // 补充证据
  evidenceUrls Json     @default("[]")
  
  createdAt    DateTime @default(now())
  
  case         ArbitrationCase @relation(fields: [caseId], references: [id])
  
  @@unique([caseId, arbitratorId])
}

// DAO 申诉
model Appeal {
  id              String   @id @default(uuid())
  caseId          String   // 关联的仲裁案件
  appellantId     String   // 申诉人 (喂价员ID)
  
  // 申诉内容
  reason          String   // 申诉理由
  evidenceUrls    Json     @default("[]") // 补充证据
  
  // 押金
  depositAmount   Float    @default(100) // 申诉押金 (USDT)
  depositPaid     Boolean  @default(false)
  depositTxHash   String?
  
  // DAO 投票 (§9.3: 7天投票期)
  votingDeadline  DateTime // 7天投票期
  supportVotes    Int      @default(0) // 支持票数 (按 FEED 持有量加权)
  rejectVotes     Int      @default(0) // 反对票数
  totalVoters     Int      @default(0) // 参与投票人数
  
  // 状态
  status          String   @default("VOTING") // VOTING / APPROVED / REJECTED / EXPIRED
  
  // 结果
  originalVerdictOverturned Boolean @default(false)
  
  resolvedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  case            ArbitrationCase @relation(fields: [caseId], references: [id])
  daoVotes        DAOVote[]

  @@index([caseId])
  @@index([status])
}

// DAO 投票记录
model DAOVote {
  id          String   @id @default(uuid())
  appealId    String
  voterId     String   // 投票人钱包地址
  
  // 投票
  vote        String   // SUPPORT / REJECT
  feedAmount  Float    // 投票时持有的 FEED 数量 (权重)
  
  createdAt   DateTime @default(now())
  
  appeal      Appeal   @relation(fields: [appealId], references: [id])
  
  @@unique([appealId, voterId])
}

// ========================================
// 培训系统 (Training System)
// ========================================

// 培训课程
model TrainingCourse {
  id          String   @id @default(uuid())
  title       String   // 课程标题
  description String   // 课程描述
  category    String   // ONBOARDING / MONTHLY / MARKET_SPECIFIC / ADVANCED
  market      String?  // 关联市场类型（可选）
  content     String   // 课程内容 (Markdown/JSON)
  duration    Int      // 预计时长（分钟）
  xpReward    Int      @default(100) // 完成奖励 XP
  isRequired  Boolean  @default(false) // 是否必修
  orderIndex  Int      @default(0) // 排序
  isActive    Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  exams       TrainingExam[]
  records     FeederTrainingRecord[]
}

// 培训考试
model TrainingExam {
  id           String   @id @default(uuid())
  courseId     String
  title        String
  questions    Json     // 题目数组
  passingScore Int      @default(80) // 及格分数
  timeLimit    Int      @default(30) // 时间限制（分钟）
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  course       TrainingCourse @relation(fields: [courseId], references: [id])
  attempts     ExamAttempt[]
}

// 考试尝试记录
model ExamAttempt {
  id          String   @id @default(uuid())
  examId      String
  feederId    String
  answers     Json     // 答案数组
  score       Int
  passed      Boolean
  startedAt   DateTime
  submittedAt DateTime @default(now())
  
  exam        TrainingExam @relation(fields: [examId], references: [id])

  @@index([examId])
  @@index([feederId])
}

// 喂价员培训记录
model FeederTrainingRecord {
  id          String    @id @default(uuid())
  feederId    String
  courseId    String
  status      String    @default("NOT_STARTED") // NOT_STARTED / IN_PROGRESS / COMPLETED
  progress    Int       @default(0) // 进度百分比
  completedAt DateTime?
  examPassed  Boolean   @default(false)
  examScore   Int?
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  feeder      Feeder         @relation(fields: [feederId], references: [id])
  course      TrainingCourse @relation(fields: [courseId], references: [id])
  
  @@unique([feederId, courseId])
}

// ========================================
// 成就系统 (Achievement System)
// ========================================

// 成就定义
model Achievement {
  id          String   @id @default(uuid())
  code        String   @unique // "FIRST_FEED", "100_FEEDS"
  name        String   // "初出茅庐"
  description String   // "完成首次喂价"
  category    String   // MILESTONE / PRECISION / SPEED / SPECIAL
  icon        String   // 图标 emoji 或 URL
  
  // 解锁条件 (JSON)
  conditions  Json     // { "totalFeeds": 1 }
  
  // 奖励
  xpReward    Int      @default(0)
  feedReward  Float    @default(0)
  nftMetadata Json?    // NFT 元数据
  
  // 稀有度
  rarity      String   @default("COMMON") // COMMON / RARE / EPIC / LEGENDARY
  
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  
  unlocks     FeederAchievement[]
}

// 喂价员成就解锁记录
model FeederAchievement {
  id            String   @id @default(uuid())
  feederId      String
  achievementId String
  unlockedAt    DateTime @default(now())
  nftTokenId    String?  // 铸造的 NFT Token ID
  
  feeder        Feeder      @relation(fields: [feederId], references: [id])
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  
  @@unique([feederId, achievementId])
}
